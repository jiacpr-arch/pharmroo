{
  "crons": [
    {
      "path": "/api/cron/generate-daily",
      "schedule": "0 2 * * *"
    },
    {
      "path": "/api/billing/reconcile",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/line/expiry-warning",
      "schedule": "0 2 * * *"
    },
    {
      "path": "/api/line/weekly-summary",
      "schedule": "0 3 * * 0"
    },
    {
      "path": "/api/blog/generate",
      "schedule": "0 19 * * 1,4"
    },
    {
      "path": "/api/cron/ad-metrics",
      "schedule": "0 */6 * * *"
    },
    {
      "path": "/api/cron/detect-underperformers",
      "schedule": "30 */6 * * *"
    },
    {
      "path": "/api/cron/process-optimizations",
      "schedule": "45 */6 * * *"
    },
    {
      "path": "/api/cron/evaluate-variants",
      "schedule": "0 4 * * *"
    }
  ],
  "functions": {
    "app/api/cron/generate-daily/route.ts": {
      "maxDuration": 300
    },
    "app/api/blog/generate/route.ts": {
      "maxDuration": 120
    },
    "app/api/billing/reconcile/route.ts": {
      "maxDuration": 60
    },
    "app/api/cron/ad-metrics/route.ts": {
      "maxDuration": 300
    },
    "app/api/cron/detect-underperformers/route.ts": {
      "maxDuration": 120
    },
    "app/api/cron/process-optimizations/route.ts": {
      "maxDuration": 300
    },
    "app/api/cron/evaluate-variants/route.ts": {
      "maxDuration": 120
    }
  }
}
