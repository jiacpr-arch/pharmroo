    "app/api/autopost/retry/route.ts": {
      "maxDuration": 60
    },
    "app/api/chat/route.ts": {
      "maxDuration": 60
    },
    "app/api/facebook/webhook/route.ts": {
      "maxDuration": 60
    },
    "app/api/line/webhook/route.ts": {
      "maxDuration": 60
    },
    "app/api/line/jiaroo-webhook/route.ts": {
      "maxDuration": 60
    }
